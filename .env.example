# ============================================================
# Virtual AI Spotter — Environment Variables
# ============================================================
# Copy this file to `.env` and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to version control!
# ============================================================

# --- AWS Cloud Upload (Optional) ---
# Set CLOUD_UPLOAD_ENABLED=true to enable session upload to AWS.
# Without these values, the app works fully offline with SQLite only.

CLOUD_UPLOAD_ENABLED=false
AWS_API_URL=https://YOUR_API_ID.execute-api.eu-west-1.amazonaws.com/prod/sessions
AWS_API_KEY=your-api-key-here

# Upload behavior
CLOUD_UPLOAD_TIMEOUT=10
CLOUD_UPLOAD_MAX_RETRIES=2

# DynamoDB table name (default: SpotterAI_Workout_Logs)
DYNAMODB_TABLE=SpotterAI_Workout_Logs
